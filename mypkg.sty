% mypkg.sty
\ProvidesPackage{mypkg}[2026/03/27 My simple package]

%%%%%%%%%%% margin chapter layout%%%%%%%%%%%%%%
\RequirePackage{tikz}
\usetikzlibrary{matrix}
% https://tex.stackexchange.com/a/761258

\ExplSyntaxOn
\tl_new:N \l_mwe_matrix_content_tl

% —— l3keys 样式变量 ——
% 颜色
\tl_new:N \l_mypkg_node_fill_color
\tl_new:N \l_mypkg_current_fill_color
\tl_new:N \l_mypkg_node_draw_color
\tl_new:N \l_mypkg_current_draw_color
% 尺寸
\dim_new:N \l_mypkg_block_size_dim
\dim_new:N \l_mypkg_block_sep_dim
% 字体
\tl_new:N \l_mypkg_font_style_tl

% —— keys 定义 ——
\keys_define:nn { mypkg }
{
    node-fill    .tl_set:N   = \l_mypkg_node_fill_color,
    node-fill    .initial:n  = cyan,
    current-fill .tl_set:N   = \l_mypkg_current_fill_color,
    current-fill .initial:n  = magenta,
    node-draw    .tl_set:N   = \l_mypkg_node_draw_color,
    node-draw    .initial:n  = none,
    current-draw .tl_set:N   = \l_mypkg_current_draw_color,
    current-draw .initial:n  = none,
    block-size   .dim_set:N  = \l_mypkg_block_size_dim,
    block-size   .initial:n  = 1.2cm,
    block-sep    .dim_set:N  = \l_mypkg_block_sep_dim,
    block-sep    .initial:n  = 0.5cm,
    font        .tl_set:N    = \l_mypkg_font_style_tl,
    font         .initial:n  = { \sffamily\bfseries\Huge },
}

% —— 用户接口 ——
\NewDocumentCommand \marginblockset { m } { 
    \keys_set:nn { mypkg } { #1 } 
}

\property_new:nnnn { last-chapter } { now } { 1 } {
    \arabic{chapter}
}
\hook_gput_code:nnn { enddocument } { . } {
  \property_record:nn { mwe/matrix } { last-chapter }
}
\hook_gput_code:nnn { shipout/background } { . } {
    \int_step_inline:nn { \property_ref:nn { mwe/matrix } { last-chapter } } {
        \int_compare:nNnT { #1 } = { \value{chapter} } {
            \tl_put_right:Nn \l_mwe_matrix_content_tl { |[fill=\l_mypkg_current_fill_color, draw=\l_mypkg_current_draw_color]| }
        }
        \tl_put_right:Nn \l_mwe_matrix_content_tl { #1 \\ }
    }
    \begin{tikzpicture}[%
            overlay,remember~picture,
            marginpage/.style={
                matrix~of~nodes,
                nodes={
                    draw=\l_mypkg_node_draw_color, align=center,
                    fill=\l_mypkg_node_fill_color, minimum~size=\l_mypkg_block_size_dim,
                    font=\l_mypkg_font_style_tl
                },
                row~sep=\l_mypkg_block_sep_dim,
                column~sep=0mm,
                inner~sep=0pt,
                outer~sep=0pt,
            }
        ]%
        % \matrix[anchor=east,marginpage] at (current~page.east){\l_mwe_matrix_content_tl};
        \if@twoside
            \ifodd\value{page}\relax
                \matrix[anchor=east,marginpage] at (current~page.east){\l_mwe_matrix_content_tl};
            \else%
                \matrix[anchor=west,marginpage] at (current~page.west){\l_mwe_matrix_content_tl};
            \fi%
        \else
            \matrix[anchor=east,marginpage] at (current~page.east){\l_mwe_matrix_content_tl};
        \fi
    \end{tikzpicture}%
}
\ExplSyntaxOff

\endinput